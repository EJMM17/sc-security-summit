# Supabase — obten estos valores en: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend — https://resend.com → API Keys (gratis tier: 3,000 emails/mes)
# REQUERIDO para que el correo de confirmación de registro se envíe.
# Si falta o queda como placeholder, el registro NO falla, pero NO se
# manda correo y queda registrado como skipped_no_api_key en email_events.
# Configúralo en Vercel para Production Y Preview, luego haz redeploy.
RESEND_API_KEY=re_PLACEHOLDER
# Remitente. El dominio DEBE estar verificado (SPF + DKIM) en Resend.
# Por defecto se envía desde "SC Security Summit <hola@scsecuritysummit.com>".
EMAIL_FROM="SC Security Summit <hola@scsecuritysummit.com>"

# Cloudflare Turnstile — https://dash.cloudflare.com → Turnstile (gratis)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA   # key pública (visible en browser)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA  # key privada (server-only)

# URL canónica para SEO (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.scsecuritysummit.com

# Email de contacto para mensajes de error al usuario
CONTACT_EMAIL=hola@scsecuritysummit.com.mx

# Admin dashboard (/admin) — passwordless magic-link auth.
# ADMIN_EMAILS: csv de correos autorizados. Si está vacío, cae a CONTACT_EMAIL.
# ADMIN_SESSION_SECRET: usado para firmar tokens y cookies. Mín. 32 chars.
#   Generar: openssl rand -base64 48
ADMIN_EMAILS=
ADMIN_SESSION_SECRET=

# Upstash Redis — Vercel Dashboard → Integrations → Upstash Redis → .env.local tab
# Requerido en producción para rate limiting distribuido multi-región.
UPSTASH_REDIS_REST_URL=https://TU_INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=TU_TOKEN_AQUI

# Sentry — sentry.io → Project → Settings → Client Keys (DSN)
# Mismo DSN para client y server. Si está vacío, Sentry se deshabilita.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source map upload (solo en Vercel/CI). Generar en
# sentry.io → User Settings → Auth Tokens con scope "project:releases".
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Conekta v2 — usa SOLO la secret key (sin public key).
# https://panel.conekta.com → Configuración → API Keys
# Modo prueba: key_xxxxxxxxxx | Producción: live_xxxxxxxxxx
CONEKTA_API_KEY=
# Opcional: secret compartido para validar firma del webhook
CONEKTA_WEBHOOK_SECRET=

# ── Analytics & Marketing Pixels ─────────────────────────────
# Google Tag Manager — https://tagmanager.google.com
# Si usas GTM, no necesitas GA_MEASUREMENT_ID (configúralo dentro de GTM)
NEXT_PUBLIC_GTM_ID=
# Google Analytics 4 (standalone, sin GTM) — https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Meta (Facebook) Pixel — https://business.facebook.com → Events Manager → Data Sources
NEXT_PUBLIC_META_PIXEL_ID=
# LinkedIn Insight Tag — https://www.linkedin.com/campaignmanager → Account Assets → Insight Tag
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
