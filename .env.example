# Public
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Server-only
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# RESEND_API_KEY: required to send the registration confirmation email.
# Missing/placeholder => registration still succeeds, no email is sent
# (logged as skipped_no_api_key in email_events). Set in Vercel Production
# AND Preview, then redeploy. EMAIL_FROM domain must be verified in Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM="SC Security Summit <hola@scsecuritysummit.com>"
CONTACT_EMAIL=ops@example.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional admin auth
ADMIN_EMAILS=ops@example.com
ADMIN_SESSION_SECRET=replace_with_32_plus_char_secret

# ── Analytics & Marketing (all NEXT_PUBLIC_) — see docs/TRACKING.md ──
# GTM is the single measurement entrypoint. When GTM is set, GA4 is loaded
# INSIDE GTM (not directly) to avoid double counting.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# Only used (loaded directly) when NEXT_PUBLIC_GTM_ID is empty.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Loaded directly (do NOT also add these in GTM, or events fire twice).
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
